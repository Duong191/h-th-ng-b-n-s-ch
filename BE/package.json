{
  "name": "be",
  "version": "1.0.0",
  "description": "Bookstore backend API with Node.js + TypeScript",
  "main": "src/server.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test:smoke": "npm run build",
    "test:db": "ts-node-dev --exit-child --transpile-only src/scripts/testDbConnection.ts",
    "seed:recovered": "ts-node-dev --exit-child --transpile-only src/scripts/applyRecoveredSeed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mssql": "^9.1.11",
    "@types/node": "^25.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
