# =============================================================================
# Backend — SQL Server (mssql / tedious)
# Copy thành file .env và điền giá trị thật. Không commit .env lên git.
# =============================================================================

# --- Phương án A (khuyến nghị khi đã biết cổng TCP): server + port, KHÔNG dùng DB_INSTANCE ---
# Tránh vừa DB_PORT vừa DB_INSTANCE — code sẽ bỏ qua DB_INSTANCE nếu có DB_PORT.
#
# Ví dụ instance mặc định lắng nghe 1433:
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=bookstore_db

DB_USE_WINDOWS_AUTH=false
DB_USER=sa
DB_PASSWORD=thay_bang_mat_khau_sa_trong_ssms

DB_TRUST_CERT=true
DB_ENCRYPT=true

# Không set DB_INSTANCE khi dùng DB_PORT (để trống hoặc xóa hẳn):
# DB_INSTANCE=

# --- Phương án B: Named instance (SQLEXPRESS) qua SQL Browser — không chỉ định port ---
# Bỏ DB_PORT hoặc comment; chỉ dùng khi Browser chạy và instance lắng nghe động.
# DB_SERVER=localhost
# DB_INSTANCE=SQLEXPRESS
# DB_NAME=bookstore_db
# DB_USE_WINDOWS_AUTH=false
# DB_USER=sa
# DB_PASSWORD=...

# --- Phương án C: Windows (NTLM) — codebase dùng NTLM với user/mật khẩu Windows ---
# DB_USE_WINDOWS_AUTH=true
# DB_USER=WINDOWS_USERNAME
# DB_PASSWORD=windows_password
# DB_DOMAIN=.
# DB_SERVER=localhost
# DB_INSTANCE=SQLEXPRESS
# (Hoặc dùng DB_PORT thay cho INSTANCE — không trộn cả hai.)

PORT=3001
CORS_ORIGIN=http://localhost:3000

JWT_ACCESS_SECRET=access_secret_dev
JWT_REFRESH_SECRET=refresh_secret_dev
